# openNexus 환경변수 설정 파일
# .env.example을 복사해서 .env로 사용: cp .env.example .env

# ===== 필수 설정 =====

# Anthropic API 키 (Claude 사용을 위해 필수)
ANTHROPIC_API_KEY=

# 사용자 식별자 (텔레그램 알림 등에 사용)
NEXUS_USER_ID=

# ===== 텔레그램 봇 설정 (선택) =====
# 텔레그램 알림을 사용하려면 아래 설정 필요

# 텔레그램 봇 토큰 (BotFather에서 발급)
TELEGRAM_BOT_TOKEN=

# 텔레그램 채팅 ID (수신자 ID)
TELEGRAM_CHAT_ID=

# ===== 경로 설정 (선택, 기본값 사용 가능) =====

# Obsidian vault 경로 (기본: ~/obsidian-vault)
OBSIDIAN_VAULT_PATH=

# context 디렉토리 경로 (기본: ~/context)
NEXUS_CONTEXT_PATH=

# skills 디렉토리 경로 (기본: ~/.claude/skills)
NEXUS_SKILLS_PATH=

# ===== 모델 설정 (선택) =====
# 사용할 Claude 모델 (기본값 사용 권장)

# 메인 모델 (기본: claude-sonnet-4-5)
AGENT_MAIN=

# 리서처 모델 (기본: claude-haiku-4-5)
AGENT_RESEARCHER=

# 리뷰어 모델 (기본: claude-opus-4-5)
AGENT_REVIEWER=
